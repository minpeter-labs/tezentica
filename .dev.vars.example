SLACK_SIGNING_SECRET=...
SLACK_BOT_TOKEN=...
OWNER_USER_ID=...
TARGET_BOT_USER_ID=...
# Private channel (owner + bots only) where Tezentica pings the target bot.
# Tezentica never writes to public channels; handoffs land here instead.
HOME_CHANNEL_ID=...
# Optional. Comma-separated Slack channels where every alert asks the target bot for severity analysis.
ALERT_CHANNEL_IDS=...
# Optional. Omit for default: "{target} 이 작업 처리하고 원본 스레드에 오너 자격으로 답해줘.\n원본 메시지:\n```{message}```"
HANDOFF_MESSAGE_TEMPLATE=...
# Optional. Used to prevent Tezentica from replying to its own alert-channel messages.
SLACK_BOT_USER_ID=...
